<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    jcr:primaryType="sling:Folder"
    jcr:title="Groups Membership Graph"
    sling:resourceType="groupsgraph/components/page">
    <picker
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/authorizable/autocomplete"
        granite:class="groupsgraph__picker"
        name="principal"
        valueType="id"
        selector="all"
        serviceUserFilter="off"
        forceSelection="{Boolean}true"
        emptyText="Search for a user or group…"/>
</jcr:root>
